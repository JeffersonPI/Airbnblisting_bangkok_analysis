                <zone h='3414' id='23' type-v2='text' w='89702' x='468' y='95693'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontsize='10'>The market is not constrained by supply, but by underperforming listings.</run>
                  </formatted-text>
                  <zone-style>
