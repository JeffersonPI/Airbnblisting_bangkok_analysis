          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='98426' x='787' y='830'>
            <zone h='3423' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone h='10477' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='4253' />
            <zone h='84440' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='14730'>
              <flipboard active-id='7' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='High availability but low demand across listings.' captured-sheet='Airbnb Bangkok Market Analysis: Supply, Demand &amp; Strategy Insights' id='1' />
                  <story-point caption='Most listings are underutilized, with high availability but low reviews.' captured-sheet='Supply vs Demand' id='2' />
                  <story-point caption='A large share of listings falls into the low demand segment.' captured-sheet='Segment Distribution' id='3' />
                  <story-point caption='Pricing does not strongly influence demand.' captured-sheet='Price vs Demand' id='4' />
                  <story-point caption='Demand varies across room types, with entire homes performing better.' captured-sheet='Room Type vs Demand' id='5' />
                  <story-point caption='Improving listing quality delivers the highest impact on demand (~30%).' captured-sheet='Strategy Impact' id='6' />
                  <story-point caption='The market is driven by underperforming listings, not limited supply.' captured-sheet='Airbnb Bangkok Market Analysis: Supply, Demand &amp; Strategy Insights' id='7' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
